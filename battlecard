function showCard() {
  const key = document.getElementById('matchup').value;
  const card = battleCards[key];
  if (!card) return;
  
  const container = document.getElementById('cards-container');
  let html = '';
  
  html += `<div class="matchup-header">
    <div class="matchup-device"><div class="name">${card.rohrer.name}</div><div class="brand">${card.rohrer.brand}</div></div>
    <div class="matchup-vs">VS</div>
    <div class="matchup-device"><div class="name">${card.competitor.name}</div><div class="brand">${card.competitor.brand}</div></div>
  </div>`;
  
  html += `<div class="opener"><div class="opener-label">Suggested opener</div><div class="opener-text">"${card.opener}"</div></div>`;
  
  html += `<div class="card"><div class="card-title">Key advantages & considerations</div>`;
  card.advantages.forEach(a => {
    let iconClass, labelClass;
    if (a.type === 'win') { iconClass = 'win-icon'; labelClass = 'win-label'; }
    else if (a.type === 'block') { iconClass = 'lose-icon'; labelClass = 'lose-label'; }
    else { iconClass = 'neutral-icon'; labelClass = 'neutral-label'; }
    
    const iconSymbol = a.type === 'win' ? '+' : a.type === 'block' ? '!' : '~';
    
    html += `<div class="win-row">
      <div class="${iconClass}">${iconSymbol}</div>
      <div class="win-text"><span class="${labelClass}">${a.label}:</span> ${a.text}</div>
    </div>`;
  });
  html += `</div>`;
  
  html += `<div class="card"><div class="card-title">Spec comparison</div>
    <table class="spec-table">
      <tr><th>Specification</th><th>${card.rohrer.name}</th><th>${card.competitor.name}</th></tr>`;
  card.specs.forEach(s => {
    html += `<tr><td>${s[0]}</td><td class="rohrer">${s[1]}</td><td class="competitor">${s[2]}</td></tr>`;
  });
  html += `</table></div>`;
  
  html += `<div class="card"><div class="card-title">Objection handling</div>`;
  card.objections.forEach(o => {
    html += `<div class="objection">
      <div class="objection-q">"${o.q}"</div>
      <div class="objection-a">${o.a}</div>
    </div>`;
  });
  html += `</div>`;
  
  container.innerHTML = html;
}

showCard();
